# word_guessing_game.py
# A simple word guessing game (like Hangman)

import random

def choose_word():
    """Return a random word from a list"""
    word_list = ["python", "developer", "programming", "hangman", "challenge", "project", "learning"]
    return random.choice(word_list)

def display_word(word, guessed_letters):
    """Show the word with underscores for unguessed letters"""
    return " ".join([letter if letter in guessed_letters else "_" for letter in word])

def main():
    print("\n" + "="*40)
    print("        WORD GUESSING GAME")
    print("="*40)
    
    word = choose_word()
    guessed = set()
    attempts = 6
    
    while attempts > 0:
        print("\n" + display_word(word, guessed))
        print(f"Attempts left: {attempts}")
        print(f"Guessed letters: {', '.join(sorted(guessed)) if guessed else 'None'}")
        
        guess = input("Guess a letter: ").lower()
        
        if len(guess) != 1 or not guess.isalpha():
            print(" please enter a single letter.")
            continue
        
        if guess in guessed:
            print(" you already guessed that letter.")
            continue
        
        guessed.add(guess)
        
        if guess in word:
            print(" correct!")
            if all(letter in guessed for letter in word):
                print(f"\n congratulations! The word was '{word}'.")
                break
        else:
            attempts -= 1
            print(" wrong!")
    
    if attempts == 0:
        print(f"\n game Over! The word was '{word}'.")

if __name__ == "__main__":
    main()
