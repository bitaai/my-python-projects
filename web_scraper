# web_scraper.py
# A simple web scraper that fetches headlines from a news website

import requests
from bs4 import BeautifulSoup

def get_headlines(url, tag, class_name, limit=5):
    """
    Fetch headlines from a given URL using BeautifulSoup.
    """
    try:
        response = requests.get(url, timeout=10)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        headlines = soup.find_all(tag, class_=class_name)
        
        result = []
        for idx, item in enumerate(headlines):
            if idx >= limit:
                break
            text = item.get_text(strip=True)
            if text:
                result.append(text)
        
        return result
    except requests.exceptions.RequestException as e:
        return {"error": str(e)}
    except Exception as e:
        return {"error": f"Parsing error: {str(e)}"}

def main():
    print("\n" + "="*40)
    print("        SIMPLE WEB SCRAPER")
    print("="*40)
    
    # Default example: BBC News headlines
    url = "https://www.bbc.com/news"
    tag = "h2"
    class_name = "sc-8ea7699c-3 dhclWg"  # BBC's headline class (may change)
    
    print(" Fetching headlines from BBC News...")
    headlines = get_headlines(url, tag, class_name, 5)
    
    if isinstance(headlines, dict) and "error" in headlines:
        print(f" Error: {headlines['error']}")
        return
    
    if not headlines:
        print(" No headlines found. The website structure may have changed.")
        return
    
    print("\n TOP HEADLINES:")
    for idx, headline in enumerate(headlines, 1):
        print(f"{idx}. {headline}")

if __name__ == "__main__":
    main()
