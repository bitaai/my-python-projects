# file_organizer.py
# organizes files in a folder by their extensions

import os
import shutil

def organize_folder(folder_path):
    """
    organize files in the given folder by moving them into subfolders
    based on their file extensions.
    """
    if not os.path.exists(folder_path):
        print(f" folder not found: {folder_path}")
        return
    
    # define folder names for different file types
    categories = {
        "images": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tiff"],
        "documents": [".pdf", ".docx", ".doc", ".txt", ".xlsx", ".pptx"],
        "archives": [".zip", ".rar", ".tar", ".gz", ".7z"],
        "videos": [".mp4", ".mkv", ".flv", ".avi", ".mov"],
        "music": [".mp3", ".wav", ".aac", ".flac"],
        "programs": [".exe", ".msi", ".sh", ".bat", ".py", ".js", ".html", ".css"],
        "others": []  # Default folder for unknown extensions
    }
    
    # create category folders if they don't exist
    for category in categories:
        category_path = os.path.join(folder_path, category)
        if not os.path.exists(category_path):
            os.makedirs(category_path)
    
    # iterate through files in the folder
    for item in os.listdir(folder_path):
        item_path = os.path.join(folder_path, item)
        
        # skip directories
        if os.path.isdir(item_path):
            continue
        
        # get file extension
        _, ext = os.path.splitext(item)
        ext = ext.lower()
        
        # find the right category
        moved = False
        for category, extensions in categories.items():
            if ext in extensions:
                shutil.move(item_path, os.path.join(folder_path, category, item))
                print(f" moved: {item} -> {category}")
                moved = True
                break
        
        # if no category found, move to "Others"
        if not moved:
            shutil.move(item_path, os.path.join(folder_path, "Others", item))
            print(f" moved: {item} -> Others")
    
    print("\n Folder organization complete!")

def main():
    print("\n" + "="*40)
    print("        FILE ORGANIZER")
    print("="*40)
    
    folder = input("Enter the folder path to organize: ").strip()
    if not folder:
        print(" no folder path provided.")
        return
    
    organize_folder(folder)

if __name__ == "__main__":
    main()
